    ; TEMP=
    MOVLW   'T'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   'M'
    CALL    UART_CHAR
    MOVLW   'P'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    MOVF    temp_val, W
    MOVWF   math_val
    CALL    BIN2BCD_8BIT
    MOVF    bcd_hund, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_tens, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_ones, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVLW   'C'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR

    ; LIGHT=
    MOVLW   'L'
    CALL    UART_CHAR
    MOVLW   'I'
    CALL    UART_CHAR
    MOVLW   'G'
    CALL    UART_CHAR
    MOVLW   'H'
    CALL    UART_CHAR
    MOVLW   'T'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    MOVF    ldr_val, W
    MOVWF   math_val
    CALL    BIN2BCD_8BIT
    MOVF    bcd_hund, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_tens, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_ones, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVLW   '%'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR

    ; FAN=
    MOVLW   'F'
    CALL    UART_CHAR
    MOVLW   'A'
    CALL    UART_CHAR
    MOVLW   'N'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    MOVF    fan_speed, W
    MOVWF   math_val
    CALL    BIN2BCD_8BIT
    MOVF    bcd_hund, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_tens, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_ones, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVLW   '%'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR

    ; LED=
    MOVLW   'L'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   'D'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    MOVF    led_speed, W
    MOVWF   math_val
    CALL    BIN2BCD_8BIT
    MOVF    bcd_hund, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_tens, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_ones, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVLW   '%'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR

    ; PEOPLE=
    MOVLW   'P'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   'O'
    CALL    UART_CHAR
    MOVLW   'P'
    CALL    UART_CHAR
    MOVLW   'L'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    MOVF    people_count, W
    MOVWF   math_val
    CALL    BIN2BCD_8BIT
    MOVF    bcd_hund, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_tens, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVF    bcd_ones, W
    ADDLW   0x30
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR

    ; MODE=
    MOVLW   'M'
    CALL    UART_CHAR
    MOVLW   'O'
    CALL    UART_CHAR
    MOVLW   'D'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    BCF     STATUS, RP0
    BCF     STATUS, RP1
    BTFSS   mode_state, 0
    GOTO    UR_MODE_N
    MOVLW   'S'
    CALL    UART_CHAR
    MOVLW   'A'
    CALL    UART_CHAR
    MOVLW   'V'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR
    GOTO    UR_MODE_DONE
UR_MODE_N:
    MOVLW   'N'
    CALL    UART_CHAR
    MOVLW   'O'
    CALL    UART_CHAR
    MOVLW   'R'
    CALL    UART_CHAR
    MOVLW   'M'
    CALL    UART_CHAR
    MOVLW   'A'
    CALL    UART_CHAR
    MOVLW   'L'
    CALL    UART_CHAR
UR_MODE_DONE:
    MOVLW   ' '
    CALL    UART_CHAR

    ; FAULT= LM35 or NONE
    MOVLW   'F'
    CALL    UART_CHAR
    MOVLW   'A'
    CALL    UART_CHAR
    MOVLW   'U'
    CALL    UART_CHAR
    MOVLW   'L'
    CALL    UART_CHAR
    MOVLW   'T'
    CALL    UART_CHAR
    MOVLW   '='
    CALL    UART_CHAR
    BCF     STATUS, RP0
    BCF     STATUS, RP1
    MOVF    fault_active, F
    BTFSC   STATUS, Z
    GOTO    UR_FAULT_NONE
    ; fault_active = 1: LM35 fault
    MOVLW   'L'
    CALL    UART_CHAR
    MOVLW   'M'
    CALL    UART_CHAR
    MOVLW   '3'
    CALL    UART_CHAR
    MOVLW   '5'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR
    GOTO    UR_CRLF
UR_FAULT_NONE:
    MOVLW   'N'
    CALL    UART_CHAR
    MOVLW   'O'
    CALL    UART_CHAR
    MOVLW   'N'
    CALL    UART_CHAR
    MOVLW   'E'
    CALL    UART_CHAR
    MOVLW   ' '
    CALL    UART_CHAR
UR_CRLF:
    MOVLW   0x0D
    CALL    UART_CHAR
    MOVLW   0x0A
    CALL    UART_CHAR
    RETURN

; ==============================================================================
; BIN2BCD_8BIT - Convert math_val (0-255) to bcd_hund, bcd_tens, bcd_ones
; ==============================================================================
BIN2BCD_8BIT:
    CLRF    bcd_hund
    CLRF    bcd_tens
    CLRF    bcd_ones
BCD_H:
    MOVLW   d'100'
    SUBWF   math_val, W
    BTFSS   STATUS, C
    GOTO    BCD_T
    MOVWF   math_val
    INCF    bcd_hund, F
    GOTO    BCD_H
BCD_T:
    MOVLW   d'10'
    SUBWF   math_val, W
    BTFSS   STATUS, C
    GOTO    BCD_O
    MOVWF   math_val
    INCF    bcd_tens, F
    GOTO    BCD_T
BCD_O:
    MOVF    math_val, W
    MOVWF   bcd_ones
    RETURN

; ==============================================================================
; LCD_INIT - 4-bit initialisation sequence
; ==============================================================================
LCD_INIT:
    BCF     LCD_RS
    NOP
    MOVLW   0x03
    CALL    LCD_NIBBLE
    CALL    DELAY_5MS
    MOVLW   0x03
    CALL    LCD_NIBBLE
    CALL    DELAY_100US
    MOVLW   0x03
    CALL    LCD_NIBBLE
    CALL    DELAY_100US
    MOVLW   0x02
    CALL    LCD_NIBBLE
    CALL    DELAY_100US
    MOVLW   0x28
    CALL    LCD_CMD
    MOVLW   0x0C
    CALL    LCD_CMD
    MOVLW   0x06
    CALL    LCD_CMD
    RETURN

; ==============================================================================
; LCD_CMD - send command byte in W (RS=0)
; ==============================================================================
LCD_CMD:
    MOVWF   lcd_data
    BCF     LCD_RS
    NOP
    SWAPF   lcd_data, W
    ANDLW   0x0F
    CALL    LCD_NIBBLE
    MOVF    lcd_data, W
    ANDLW   0x0F
    CALL    LCD_NIBBLE
    CALL    DELAY_100US
    RETURN

; ==============================================================================
; LCD_CHAR - send data byte in W (RS=1)
; ==============================================================================
LCD_CHAR:
    MOVWF   lcd_data
    BSF     LCD_RS
    NOP
    SWAPF   lcd_data, W
    ANDLW   0x0F
    CALL    LCD_NIBBLE
    MOVF    lcd_data, W
    ANDLW   0x0F
    CALL    LCD_NIBBLE
    CALL    DELAY_100US
    RETURN

; ==============================================================================
; LCD_NIBBLE - send lower 4 bits of W to LCD data pins, pulse EN
; ==============================================================================
LCD_NIBBLE:
    MOVWF   lcd_temp
    MOVF    LCD_PORT, W
    ANDLW   0xF0
    IORWF   lcd_temp, W
    MOVWF   LCD_PORT
    BSF     LCD_EN
    NOP
    NOP
    BCF     LCD_EN
    RETURN

; ==============================================================================
; Delay subroutines (startup and ADC settling only)
; ==============================================================================
DELAY_100MS:
    MOVLW   d'100'
    GOTO    DELAY_MS_LOOP
DELAY_15MS:
    MOVLW   d'15'
    GOTO    DELAY_MS_LOOP
DELAY_5MS:
    MOVLW   d'5'
    GOTO    DELAY_MS_LOOP
DELAY_MS_LOOP:
    MOVWF   d2
DMS_O:
    MOVLW   d'249'
    MOVWF   d1
DMS_I:
    NOP
    DECFSZ  d1, F
    GOTO    DMS_I
    DECFSZ  d2, F
    GOTO    DMS_O
    RETURN

DELAY_100US:
    MOVLW   d'33'
    MOVWF   d1
DUS:
    DECFSZ  d1, F
    GOTO    DUS
    RETURN

    END
